# Frontend config for API base URL
VITE_API_URL=http://127.0.0.1:8000
# Google OAuth client ID (create credentials at https://console.cloud.google.com/apis/credentials)
# Replace with your OAuth Client ID. Example: "1234-abc.apps.googleusercontent.com"
VITE_GOOGLE_CLIENT_ID=
# Facebook App ID (create an app at https://developers.facebook.com/apps)
# Replace with your Facebook App ID. Example: "123456789012345"
VITE_FACEBOOK_APP_ID=
