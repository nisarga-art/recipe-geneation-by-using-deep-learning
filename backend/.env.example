# ── PostgreSQL (pgAdmin) ───────────────────────────────────
# Format: postgresql://<user>:<password>@<host>:<port>/<dbname>
DATABASE_URL=postgresql://postgres:admin123@localhost:5432/recipe_db

# ── Clarifai ───────────────────────────────────────────────
# Get your PAT from: https://clarifai.com/settings/security
CLARIFAI_PAT=d3387b5059844612ace18b72598d0a79
CLARIFAI_USER_ID=clarifai
CLARIFAI_APP_ID=main
CLARIFAI_MODEL_ID=food-item-recognition
CLARIFAI_MODEL_VERSION=1d5fd481e0cf4826aa72ec3ff049e044
# Optional: enable Clarifai text search (needed for /recipes/search query fallback)
# Pick a text model that returns concepts, e.g. "text-general" from Clarifai's public models
# and set its version ID from the model page.
CLARIFAI_TEXT_MODEL_ID=
CLARIFAI_TEXT_MODEL_VERSION=

# ── JWT Auth ───────────────────────────────────────────────
SECRET_KEY=replace-with-a-long-random-string-at-least-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
